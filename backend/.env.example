# ─────────────────────────────────────────
#  BACKEND — variáveis de ambiente
#  Copie este arquivo para .env e preencha
# ─────────────────────────────────────────

# Banco de dados PostgreSQL
# Exemplo Railway:  postgresql://postgres:senha@host.railway.app:5432/railway
DATABASE_URL="postgresql://usuario:senha@host:5432/ordem_servico?schema=public"

# JWT — use uma string longa e aleatória (min. 32 chars)
# Gere uma: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="TROQUE-POR-UMA-STRING-LONGA-E-ALEATORIA"
JWT_EXPIRES_IN="7d"

# Porta (plataformas como Render/Railway definem automaticamente)
PORT=3333

# Ambiente
NODE_ENV="production"

# URL do frontend em produção (sem barra no final)
CORS_ORIGIN="https://seu-frontend.vercel.app"

# ── Usuário administrador inicial (usado pelo npm run seed) ──
ADMIN_NOME="Seu Nome"
ADMIN_EMAIL="seu@email.com"
ADMIN_SENHA="senha-forte-aqui"

# ── Dados da empresa no comprovante PDF ──
EMPRESA_NOME="Nome da Sua Oficina"
EMPRESA_TELEFONE="(48) 00000-0000"
EMPRESA_ENDERECO="Rua Exemplo, 123 — Cidade/SC"
EMPRESA_DOCUMENTO="CNPJ 00.000.000/0001-00"
EMPRESA_RESPONSAVEL="Nome do Responsável"
