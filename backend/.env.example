# Conexão com o PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ordem_servico?schema=public"

# Segredo usado para assinar os tokens JWT (troque por algo longo e aleatório)
JWT_SECRET="troque-este-segredo-por-uma-string-bem-longa-e-aleatoria"
JWT_EXPIRES_IN="7d"

# Porta da API
PORT=3333

# Origem permitida no CORS (URL do frontend)
CORS_ORIGIN="http://localhost:5173"

# Dados da empresa exibidos no comprovante em PDF
EMPRESA_NOME="Sua Assistência Técnica"
EMPRESA_TELEFONE="(48) 0000-0000"
EMPRESA_ENDERECO="Rua Exemplo, 123 — Florianópolis/SC"
EMPRESA_DOCUMENTO="CNPJ 00.000.000/0001-00"
