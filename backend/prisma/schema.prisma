generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN_LOJA
  TECNICO
}

enum StatusOS {
  ABERTA
  EM_ANALISE
  AGUARDANDO_APROVACAO
  APROVADA
  EM_REPARO
  CONCLUIDA
  ENTREGUE
  CANCELADA
}

model Loja {
  id        String   @id @default(uuid())
  nome      String
  telefone  String?
  endereco  String?
  documento String?
  responsavel String?
  ativa     Boolean  @default(true)
  users     User[]
  clientes  Cliente[]
  ordens    OrdemServico[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  role      Role     @default(TECNICO)
  loja      Loja?    @relation(fields: [lojaId], references: [id])
  lojaId    String?
  ordens    OrdemServico[] @relation("TecnicoResponsavel")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lojaId])
}

model Cliente {
  id        String   @id @default(uuid())
  loja      Loja     @relation(fields: [lojaId], references: [id])
  lojaId    String
  nome      String
  telefone  String
  email     String?
  cpfCnpj   String?
  endereco  String?
  bairro    String?
  cep       String?
  ordens    OrdemServico[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lojaId])
}

model OrdemServico {
  id      String @id @default(uuid())
  loja    Loja   @relation(fields: [lojaId], references: [id])
  lojaId  String

  // Número sequencial por loja (gerado no controller)
  numero  Int

  cliente               Cliente  @relation(fields: [clienteId], references: [id])
  clienteId             String
  informacoesAdicionais String?
  objetoConserto        String?
  equipamento           String?
  acessorios            String?
  marca                 String
  modelo                String
  serie                 String?
  imei                  String?
  senhaAparelho         String?
  condicoes             String?
  defeitoRelatado       String
  laudoTecnico          String?
  solucao               String?
  termoGarantia         String?
  garantiaMeses         Int      @default(3)
  valorMercadorias      Decimal  @default(0) @db.Decimal(10, 2)
  valorServicos         Decimal  @default(0) @db.Decimal(10, 2)
  descontoValor         Decimal  @default(0) @db.Decimal(10, 2)
  descontoPercentual    Decimal  @default(0) @db.Decimal(5, 2)
  observacoes           String?
  status                StatusOS @default(ABERTA)
  tecnico               User?    @relation("TecnicoResponsavel", fields: [tecnicoId], references: [id])
  tecnicoId             String?
  dataEntrada           DateTime @default(now())
  dataPrevisao          DateTime?
  dataEntrega           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([lojaId, numero])
  @@index([lojaId, status])
  @@index([clienteId])
}
